generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  datasets      Dataset[]
  apiKeys       ApiKey[]
  modelRuns     ModelRun[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Dataset {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  filePath        String
  fileName        String
  dataDictionary  Json?
  uploadedAt      DateTime         @default(now())
  analysisResults AnalysisResult[]
  versions        DatasetVersion[]

  @@map("dataset")
}

enum RunStatus {
  AWAITING_REVIEW
  APPROVED
  REJECTED
  MONITORING
  RETRAINING_RECOMMENDED
  ARCHIVED
}

enum JobStatus {
  QUEUED
  PROCESSING
  PASSED
  FAILED
}

model DatasetVersion {
  id           String      @id @default(uuid())
  datasetId    String      
  dataset      Dataset     @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version      Int         @default(1)
  rowCount     Int?
  schemaHash   String?     // Tracks if columns changed
  createdAt    DateTime    @default(now())
  
  ModelRuns    ModelRun[]

  @@map("dataset_version")
}

model ModelRun {
  id                  String         @id @default(uuid())
  datasetVersionId    String
  DatasetVersion      DatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Cascade)
  userId              String         
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status              RunStatus      @default(AWAITING_REVIEW)
  validationStatus    JobStatus      @default(QUEUED)
  
  benchmarkScore      Float?         
  driftSeverity       String?        // LOW, MEDIUM, HIGH
  governanceScore     Float?
  stabilityScore      Float?
  metadataJson        Json?
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  AuditLogs           AuditLog[]

  @@map("model_run")
}

model AuditLog {
  id          String   @id @default(uuid())
  runId       String
  ModelRun    ModelRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  actorId     String   // User ID or 'System'
  eventType   String   // e.g., 'APPROVAL_GRANTED', 'DRIFT_DETECTED'
  severity    String   @default("INFO")
  phase       String   @default("UNKNOWN")
  comments    String?
  timestamp   DateTime @default(now())

  @@map("audit_log")
}

model AnalysisResult {
  id          String   @id @default(uuid())
  datasetId   String
  dataset     Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  issueType   String
  severity    String   // HIGH, MEDIUM, LOW
  description String
  suggestion  String
  impactScore String
  rawJson     Json
  createdAt   DateTime @default(now())

  @@map("analysis_result")
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String   @default("DataScope SDK Key")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("api_key")
}
